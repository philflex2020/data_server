#!/usr/bin/env python3
"""
config_aws <ip> [--help]

Show key config files from the aws-sim node (fractal-phil) via SSH.

Configs shown:
  git            current branch + last commit
  subscriber     subscriber/api/config.fractal.yaml
  flashmq        /etc/flashmq/flashmq.conf
  telegraf       /etc/telegraf/telegraf.conf
  influxdb        /etc/influxdb/config.toml (if present)

Usage:
  config_aws 192.168.86.51              # show all configs
  config_aws 192.168.86.51 subscriber   # show one config
  config_aws --help
"""

import sys
import argparse
import subprocess

# ── colours ──────────────────────────────────────────────────────────────────

CYAN   = "\033[36m"
YELLOW = "\033[33m"
GREY   = "\033[90m"
RESET  = "\033[0m"
BOLD   = "\033[1m"

# fractal-phil uses ~/data_server (not ~/work/gen-ai/data_server)
REPO = "~/data_server"

# ── ssh helper ────────────────────────────────────────────────────────────────

def ssh(host, cmd, password=None):
    if password:
        result = subprocess.run(
            ["sshpass", "-p", password, "ssh", "-o", "StrictHostKeyChecking=no",
             "-o", "ConnectTimeout=5", f"phil@{host}", cmd],
            capture_output=True, text=True
        )
    else:
        result = subprocess.run(
            ["ssh", "-o", "StrictHostKeyChecking=no", "-o", "ConnectTimeout=5",
             "-o", "BatchMode=yes", f"phil@{host}", cmd],
            capture_output=True, text=True
        )
    return result.stdout.strip(), result.stderr.strip()

def show_section(title, content, note=""):
    print(f"\n{BOLD}{CYAN}{'─'*60}{RESET}")
    print(f"{BOLD}{CYAN}  {title}{RESET}", end="")
    if note:
        print(f"  {GREY}{note}{RESET}", end="")
    print()
    print(f"{CYAN}{'─'*60}{RESET}")
    if content:
        print(content)
    else:
        print(f"  {YELLOW}(not found){RESET}")

# ── config sections ───────────────────────────────────────────────────────────

def show_git(host, password):
    out, _ = ssh(host,
        f"cd {REPO} && git branch --show-current && git log --oneline -3",
        password)
    show_section("git  branch + recent commits", out)

def show_subscriber(host, password):
    out, _ = ssh(host,
        f"cat {REPO}/subscriber/api/config.fractal.yaml 2>/dev/null || "
        f"cat {REPO}/subscriber/api/config.yaml 2>/dev/null",
        password)
    show_section("subscriber_api  config.fractal.yaml", out)

def show_flashmq(host, password):
    out, _ = ssh(host,
        "cat /etc/flashmq/flashmq.conf 2>/dev/null; "
        "echo '--- bridge configs ---'; "
        "cat /etc/flashmq/bridge-conf.d/*.conf 2>/dev/null || echo '(no bridge configs)'",
        password)
    show_section("flashmq  /etc/flashmq/", out)

def show_telegraf(host, password):
    out, _ = ssh(host,
        "cat /etc/telegraf/telegraf.conf 2>/dev/null || "
        "cat /etc/telegraf/telegraf.d/*.conf 2>/dev/null || echo '(not found)'",
        password)
    show_section("telegraf  /etc/telegraf/", out)

def show_influxdb(host, password):
    out, _ = ssh(host,
        "cat /etc/influxdb/config.toml 2>/dev/null || "
        "influx config list 2>/dev/null || echo '(config not found)'",
        password)
    show_section("influxdb  config", out)

# ── registry ──────────────────────────────────────────────────────────────────

CONFIGS = {
    "git":        show_git,
    "subscriber": show_subscriber,
    "flashmq":    show_flashmq,
    "telegraf":   show_telegraf,
    "influxdb":   show_influxdb,
}

# ── main ───────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Show config files from the aws-sim node (fractal-phil).",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="\n".join(f"  {name}" for name in CONFIGS),
    )
    parser.add_argument("host", nargs="?", help="IP address of the aws-sim node")
    parser.add_argument("configs", nargs="*",
                        help=f"configs to show (default: all). Choices: {', '.join(CONFIGS)}")
    parser.add_argument("--password", "-p", default=None,
                        help="SSH password (uses key auth if omitted)")
    args = parser.parse_args()

    if not args.host:
        parser.print_help()
        sys.exit(0)

    host     = args.host
    chosen   = args.configs if args.configs else list(CONFIGS)
    password = args.password

    unknown = [c for c in chosen if c not in CONFIGS]
    if unknown:
        print(f"Unknown config(s): {', '.join(unknown)}")
        print(f"Available: {', '.join(CONFIGS)}")
        sys.exit(1)

    print(f"\n{BOLD}config_aws  target={host}  sections={', '.join(chosen)}{RESET}")

    for name in chosen:
        CONFIGS[name](host, password)

    print(f"\n{CYAN}{'─'*60}{RESET}\n")

if __name__ == "__main__":
    main()
