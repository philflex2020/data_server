#!/usr/bin/env python3
"""
config_host <ip> [--help]

Show key config files from a data_server host node via SSH.

Configs shown:
  writer       source/parquet_writer_cpp/config.yaml
  stress       source/stress_runner/config.yaml
  push_agent   source/rsync_push/config.yaml
  flashmq      /etc/flashmq/flashmq.conf  (or bridge conf dir)
  git          current branch + last commit

Usage:
  config_host 192.168.86.20           # show all configs
  config_host 192.168.86.20 writer    # show one config
  config_host --help
"""

import sys
import argparse
import subprocess

# ── colours ──────────────────────────────────────────────────────────────────

CYAN   = "\033[36m"
YELLOW = "\033[33m"
GREY   = "\033[90m"
RESET  = "\033[0m"
BOLD   = "\033[1m"

REPO = "~/work/gen-ai/data_server"

# ── ssh helper ────────────────────────────────────────────────────────────────

def ssh(host, cmd, password=None):
    if password:
        result = subprocess.run(
            ["sshpass", "-p", password, "ssh", "-o", "StrictHostKeyChecking=no",
             "-o", "ConnectTimeout=5", f"phil@{host}", cmd],
            capture_output=True, text=True
        )
    else:
        result = subprocess.run(
            ["ssh", "-o", "StrictHostKeyChecking=no", "-o", "ConnectTimeout=5",
             "-o", "BatchMode=yes", f"phil@{host}", cmd],
            capture_output=True, text=True
        )
    return result.stdout.strip(), result.stderr.strip()

def show_section(title, content, note=""):
    print(f"\n{BOLD}{CYAN}{'─'*60}{RESET}")
    print(f"{BOLD}{CYAN}  {title}{RESET}", end="")
    if note:
        print(f"  {GREY}{note}{RESET}", end="")
    print()
    print(f"{CYAN}{'─'*60}{RESET}")
    if content:
        print(content)
    else:
        print(f"  {YELLOW}(not found){RESET}")

# ── config sections ───────────────────────────────────────────────────────────

def show_git(host, password):
    out, _ = ssh(host,
        f"cd {REPO} && git branch --show-current && git log --oneline -3",
        password)
    show_section("git  branch + recent commits", out)

def show_writer(host, password):
    out, _ = ssh(host, f"cat {REPO}/source/parquet_writer_cpp/config.yaml", password)
    show_section("writer  config.yaml", out)

def show_stress(host, password):
    out, _ = ssh(host, f"cat {REPO}/source/stress_runner/config.yaml", password)
    show_section("stress_runner  config.yaml", out)

def show_push_agent(host, password):
    out, _ = ssh(host, f"cat {REPO}/source/rsync_push/config.yaml", password)
    show_section("push_agent  config.yaml", out)

def show_flashmq(host, password):
    out, _ = ssh(host,
        "cat /etc/flashmq/flashmq.conf 2>/dev/null; "
        "echo '--- bridge configs ---'; "
        "cat /etc/flashmq/bridge-conf.d/*.conf 2>/dev/null || echo '(no bridge configs)'",
        password)
    show_section("flashmq  /etc/flashmq/", out)

# ── registry ──────────────────────────────────────────────────────────────────

CONFIGS = {
    "git":        show_git,
    "writer":     show_writer,
    "stress":     show_stress,
    "push_agent": show_push_agent,
    "flashmq":    show_flashmq,
}

# ── main ───────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Show config files from a data_server host node.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="\n".join(f"  {name}" for name in CONFIGS),
    )
    parser.add_argument("host", nargs="?", help="IP address of the host")
    parser.add_argument("configs", nargs="*",
                        help=f"configs to show (default: all). Choices: {', '.join(CONFIGS)}")
    parser.add_argument("--password", "-p", default=None,
                        help="SSH password (uses key auth if omitted)")
    args = parser.parse_args()

    if not args.host:
        parser.print_help()
        sys.exit(0)

    host    = args.host
    chosen  = args.configs if args.configs else list(CONFIGS)
    password = args.password

    unknown = [c for c in chosen if c not in CONFIGS]
    if unknown:
        print(f"Unknown config(s): {', '.join(unknown)}")
        print(f"Available: {', '.join(CONFIGS)}")
        sys.exit(1)

    print(f"\n{BOLD}config_host  target={host}  sections={', '.join(chosen)}{RESET}")

    for name in chosen:
        CONFIGS[name](host, password)

    print(f"\n{CYAN}{'─'*60}{RESET}\n")

if __name__ == "__main__":
    main()
